{
  "name": "clogdy",
  "version": "0.0.0",
  "private": true,
  "description": "Logdy middlewares and column definitions for parsing Claude Code transcripts",
  "workspaces": ["tui"],
  "exports": {
    "./sessions": "./scripts/lib/sessions.ts"
  },
  "scripts": {
    "check": "tsc --noEmit && bun run --filter '@clogdy/tui' check",
    "test": "bun test",
    "build": "tsc --noEmit && bun run scripts/build-config.ts",
    "follow": "bun run scripts/follow.ts",
    "snapshot": "bun run scripts/snapshot.ts",
    "picker": "bun run tui/picker.tsx",
    "tui": "bun run tui/picker.tsx",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.9",
    "typescript": "^5.5.0"
  }
}
